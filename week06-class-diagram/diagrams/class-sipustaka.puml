@startuml
hide circle
skinparam classAttributeIconSize 0

class Buku {
  +isbn: String
  +judul: String
  +kategori: String
  +jumlahEksemplar: Number
  +eksemplarTersedia: Number
}

class Anggota {
  +id: Number
  +nama: String
  +email: String
}

class Peminjaman {
  +id: Number
  +tanggalPinjam: Date
  +status: String
}

class Perpustakaan {
  -buku: Buku[]
  -anggota: Anggota[]
  -peminjaman: Peminjaman[]
  -nomorPeminjaman: Number
  +tambahBuku(buku: Buku)
  +tambahAnggota(anggota: Anggota)
  +pinjamkan(isbn, idAnggota, tanggal): Peminjaman
  +daftarPeminjamanAktif(): Peminjaman[]
}

Perpustakaan "1" o-- "0..*" Buku : mengelola
Perpustakaan "1" o-- "0..*" Anggota : mendaftarkan
Perpustakaan "1" o-- "0..*" Peminjaman : mencatat
Peminjaman "0..*" --> "1" Buku : buku
Peminjaman "0..*" --> "1" Anggota : peminjam
@enduml
