@startuml
start
:Anggota mengajukan peminjaman;
if (Buku tersedia?) then (Ya)
  if (Ada tunggakan?) then (Ya)
    :Tolak: selesaikan tunggakan;
  else (Tidak)
    if (Buku aktif >= 3?) then (Ya)
      :Tolak: batas peminjaman tercapai;
